# ---------- Application ----------
# Set production if deploying on server
NODE_ENV=production

# ---------- Database (PostgreSQL) ----------
# For local (outside Docker):
# DATABASE_URL=postgresql://casino:casino@localhost:5432/casino?schema=public
# For Docker: the app connects to service "postgres"
DATABASE_URL=postgresql://casino:casino@postgres:5432/casino?schema=public
DATABASE_URL_UNPOOLED=postgresql://casino:casino@postgres:5432/casino?schema=public
SHADOW_DATABASE_URL=postgresql://casino:casino@postgres:5432/casino?schema=public

# ---------- Mini App external links ----------
# Public URL to open the Telegram Mini App (set to your domain)
TELEGRAM_MINI_APP_URL=https://your-domain.tld
NEXT_PUBLIC_MINI_APP_URL=https://your-domain.tld

# Optional external pages (empty = hidden)
TOPUP_URL=
NEXT_PUBLIC_TOPUP_URL=
WITHDRAW_URL=
NEXT_PUBLIC_WITHDRAW_URL=

# ---------- Payments (optional) ----------
NEXT_PUBLIC_YOOKASSA_MOBILE_SDK_KEY=

# ---------- Admin panel ----------
# If set, admin pages will require a cookie with sha256(ADMIN_SECRET)
ADMIN_SECRET=

# ---------- Telegram Bot (used by ASTROBOT container) ----------
# Provide real bot token in server .env (do NOT commit)
TELEGRAM_BOT_TOKEN=
# In Docker the bot talks to the web container
BACKEND_BASE_URL=http://web:3000
SUPPORT_CHAT_URL=


